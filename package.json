{
  "name": "@jojotique/fexios",
  "version": "1.0.0",
  "description": "Library for making AJAX calls based on the fetch API",
  "type": "module",
  "files": [
    "dist",
    "types/index.d.ts"
  ],
  "keywords": [
    "fetch",
    "ajax",
    "http",
    "promise",
    "node",
    "browser",
    "axios"
  ],
  "author": "Giildo <giildo.jm@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Giildo/fexios.git"
  },
  "bugs": {
    "url": "https://github.com/Giildo/fexios/issues"
  },
  "homepage": "https://github.com/Giildo/fexios#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "run-s type-check build-only",
    "build-only": "vite build",
    "check": "run-s lint format",
    "dev": "vite",
    "format": "prettier --config ../../.prettierrc.json --ignore-path ../../.prettierignore --write src/",
    "format:silent": "prettier --config ../../.prettierrc.json --ignore-path ../../.prettierignore --log-level silent --write src/",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint . --fix",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "test:unit": "vitest",
    "type-check": "tsc"
  },
  "main": "./dist/fexios.js",
  "module": "./dist/fexios.js",
  "types": "./types/index.d.ts",
  "exports": {
    "types": "./types/index.d.ts",
    "import": "./dist/fexios.js",
    "require": "./dist/fexios.umd.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@jojotique/server": "latest",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.8.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.3.23",
    "eslint": "^9.38.0",
    "eslint-plugin-oxlint": "1.20.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "26.1.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.23.0",
    "prettier": "3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "npm:rolldown-vite@^7.1.17",
    "vitest": "^3.2.4"
  }
}