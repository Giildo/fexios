{
  "name": "@giildo/fexios",
  "version": "1.1.1",
  "description": "Library for making AJAX calls based on the fetch API",
  "keywords": [
    "ajax",
    "axios",
    "browser",
    "fetch",
    "http",
    "node",
    "promise"
  ],
  "homepage": "https://github.com/Giildo/fexios#readme",
  "bugs": {
    "url": "https://github.com/Giildo/fexios/issues"
  },
  "license": "MIT",
  "author": "Giildo <giildo.jm@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Giildo/fexios.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "run-s type-check build-only",
    "build-only": "vite build",
    "check": "run-s lint format",
    "dev": "vite",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt .",
    "test:unit": "vitest",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.69.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "lefthook": "^2.1.9",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "~1.69.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
